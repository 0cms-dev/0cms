# ZeroCMS GitHub OAuth Credentials
# Create a GitHub OAuth App at https://github.com/settings/developers
# Callback URL for local dev: http://localhost:3000/github/callback
# Callback URL for production: https://your-project.pages.dev/github/callback

GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Optional: Port settings
# PORT=3000
